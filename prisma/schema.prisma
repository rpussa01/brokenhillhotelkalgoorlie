generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  RECEIVED
  ACCEPTED
  COOKING
  READY
  COLLECTED
  CANCELLED
}

enum PaymentMethod {
  ONLINE
  PICKUP
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  PAY_AT_PICKUP
  REFUNDED
}

model Settings {
  id             String   @id @default("main")
  venueName      String
  phone          String
  address        String
  isOrderingOpen Boolean  @default(true)
  pickupMinutes  Int      @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id           String  @id @default(cuid())
  name         String
  description  String?
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  items MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?

  featured      Boolean @default(false)
  chefFavourite Boolean @default(false)
  popular       Boolean @default(false)

  dietary String[] @default([])

  available  Boolean @default(true)
  dineInOnly Boolean @default(false)
  takeaway   Boolean @default(true)

  displayOrder Int @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  orderLines OrderLine[] @relation("MenuItemOrderLines")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([available])
  @@index([featured])
  @@index([chefFavourite])
}

model Special {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  day         String?
  badge       String?
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderLines OrderLine[] @relation("SpecialOrderLines")

  @@index([active, sortOrder])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     Int           @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  pickupTime      DateTime
  notes           String?
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus
  stripeSessionId String?       @unique
  status          OrderStatus
  subtotalCents   Int
  totalCents      Int
  lines           OrderLine[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([paymentStatus])
  @@index([pickupTime])
  @@index([customerPhone])
}

model OrderLine {
  id             String  @id @default(cuid())
  orderId        String
  itemId         String?
  specialId      String?
  name           String
  quantity       Int
  unitPriceCents Int
  notes          String?

  order   Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item    MenuItem? @relation("MenuItemOrderLines", fields: [itemId], references: [id], onDelete: SetNull)
  special Special?  @relation("SpecialOrderLines", fields: [specialId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([itemId])
  @@index([specialId])
}

model Counter {
  id    String @id
  value Int    @default(0)
}

model KitchenSettings {
  id          String   @id @default("main")
  isOpen      Boolean  @default(true)
  closedTitle String   @default("Kitchen currently closed")
  closedNote  String   @default("Online ordering is unavailable right now. Please check again later.")
  updatedAt   DateTime @updatedAt
}
